<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <%# Header %>
  <div class="mb-8 flex justify-between items-center animate-fade-in">
    <div>
      <h1 class="text-4xl md:text-5xl font-bold tracking-tight text-slate-800 dark:text-slate-100">
        Analytics
      </h1>
      <p class="mt-2 text-lg text-gray-600 dark:text-gray-400">
        Workflow usage, agent performance, and operational insights.
      </p>
    </div>
    <div class="flex items-center gap-3">
      <%= link_to admin_analytics_path(format: :csv, **request.query_parameters), class: "bg-slate-600 hover:bg-slate-700 text-white px-4 py-2 rounded-full text-sm font-medium shadow-md hover:shadow-lg transition-all duration-300 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 dark:focus:ring-offset-slate-800 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        Export CSV
      <% end %>
      <%= link_to admin_root_path, class: "bg-slate-600 hover:bg-slate-700 text-white px-4 py-2 rounded-full text-sm font-medium shadow-md hover:shadow-lg transition-all duration-300 hover:scale-105 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 dark:focus:ring-offset-slate-800 inline-flex items-center" do %>
        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Dashboard
      <% end %>
    </div>
  </div>

  <%# Filters (wraps with analytics-filters controller for button/tab state) %>
  <%= render "filters" %>

  <%# Stat Cards %>
  <%= render "stat_cards" %>

  <%# Tabs — active tab preserved across filter changes via ?tab= param %>
  <% active_tab = (params[:tab] || "0").to_i %>
  <div class="mt-8" data-controller="tabs" data-tabs-active-value="<%= active_tab %>">
    <div class="border-b border-slate-200 dark:border-slate-700 mb-6">
      <nav class="-mb-px flex space-x-8">
        <% %w[Overview Workflows Agents Operations].each_with_index do |label, i| %>
          <% is_active = i == active_tab %>
          <button data-tabs-target="tab" data-action="click->tabs#switch"
                  class="whitespace-nowrap pb-4 px-1 border-b-2 font-medium text-sm transition-colors duration-200
                         <%= is_active ? 'border-slate-600 text-slate-700 dark:border-slate-400 dark:text-slate-200' : 'border-transparent text-gray-500 dark:text-gray-400' %>"
                  aria-selected="<%= is_active %>">
            <%= label %>
          </button>
        <% end %>
      </nav>
    </div>

    <%# Tab Panels %>
    <div data-tabs-target="panel" class="<%= 'hidden' unless active_tab == 0 %>">
      <%= render "tab_overview" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'hidden' unless active_tab == 1 %>">
      <%= render "tab_workflows" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'hidden' unless active_tab == 2 %>">
      <%= render "tab_agents" %>
    </div>
    <div data-tabs-target="panel" class="<%= 'hidden' unless active_tab == 3 %>">
      <%= render "tab_operations" %>
    </div>
  </div>
</div>
