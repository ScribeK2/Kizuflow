<div class="page-content">
  <div class="mb-4">
    <h1>New Template</h1>
    <p class="text-sm mt-1">Create a new workflow template.</p>
  </div>

  <%= form_with model: [:admin, @template], local: true, class: "card" do |form| %>
    <% if @template.errors.any? %>
      <div class="card__body">
        <div class="flash flash--alert">
          <div class="flash__body">
            <p class="font-medium"><%= pluralize(@template.errors.count, "error") %> prohibited this template from being saved:</p>
            <ul class="list-disc pl-5 mt-2 text-sm">
              <% @template.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="card__body">
      <div class="form-group">
        <%= form.label :name, class: "form-label" %>
        <%= form.text_field :name, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, rows: 4, class: "form-textarea" %>
      </div>

      <div class="form-group">
        <%= form.label :category, class: "form-label" %>
        <%= form.text_field :category, class: "form-input", placeholder: "e.g., onboarding, troubleshooting, training" %>
      </div>

      <div class="form-group flex items-center gap-2">
        <%= form.check_box :is_public, class: "form-checkbox" %>
        <%= form.label :is_public, "Make this template public", class: "form-label mb-0" %>
      </div>

      <div class="form-group">
        <%= form.label :workflow_data, "Workflow Steps (JSON)", class: "form-label" %>
        <p class="form-hint">Enter workflow steps as JSON array. For now, you can create templates from existing workflows using the "Save as Template" feature.</p>
        <%= form.text_area :workflow_data, value: (@template.workflow_data.to_json if @template.workflow_data.present?), rows: 10, class: "form-textarea font-mono text-sm" %>
      </div>
    </div>

    <div class="card__footer flex justify-end gap-3">
      <%= link_to admin_templates_path, class: "btn btn--plain" do %>
        Cancel
      <% end %>
      <%= form.submit "Create Template", class: "btn btn--primary" %>
    </div>
  <% end %>
</div>
