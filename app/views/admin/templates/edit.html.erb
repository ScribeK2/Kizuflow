<div class="page-content">
  <div class="mb-4">
    <h1>Edit Template</h1>
    <p class="text-sm mt-1">Modify template details.</p>
  </div>

  <%= form_with model: [:admin, @template], local: true, class: "card" do |form| %>
    <% if @template.errors.any? %>
      <div class="card__body">
        <div class="flash flash--alert">
          <div class="flash__body">
            <p class="font-medium"><%= pluralize(@template.errors.count, "error") %> prohibited this template from being saved:</p>
            <ul class="list-disc pl-5 mt-2 text-sm">
              <% @template.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="card__body">
      <div class="form-group">
        <%= form.label :name, class: "form-label" %>
        <%= form.text_field :name, class: "form-input" %>
      </div>

      <div class="form-group">
        <%= form.label :description, class: "form-label" %>
        <%= form.text_area :description, rows: 4, class: "form-textarea" %>
      </div>

      <div class="form-group">
        <%= form.label :category, class: "form-label" %>
        <%= form.text_field :category, class: "form-input", placeholder: "e.g., troubleshooting, account-management, complaints-retention" %>
      </div>

      <div class="form-group flex items-center gap-2">
        <%= form.check_box :is_public, class: "form-checkbox" %>
        <%= form.label :is_public, "Make this template public", class: "form-label mb-0" %>
      </div>

      <%# Mode Toggle (graph mode templates) %>
      <% if @template.graph_mode? && @template.workflow_data.present? %>
        <div class="mb-4" data-controller="view-mode-toggle">
          <input type="hidden" name="template[editor_mode]" value="list" data-view-mode-toggle-target="modeInput">
          <div class="inline-flex rounded border gap-1 p-0.5">
            <button type="button"
                    data-action="click->view-mode-toggle#switchToList"
                    data-view-mode-toggle-target="listBtn"
                    class="btn btn--sm btn--plain">
              JSON
            </button>
            <button type="button"
                    data-action="click->view-mode-toggle#switchToVisual"
                    data-view-mode-toggle-target="visualBtn"
                    class="btn btn--sm btn--primary">
              Visual
            </button>
          </div>
        </div>
      <% end %>

      <%# JSON Editor (list mode) %>
      <div id="list-editor-container">
        <div class="form-group">
          <%= form.label :workflow_data, "Workflow Steps (JSON)", class: "form-label" %>
          <p class="form-hint">Workflow steps as JSON array. Use the Visual tab for a drag-and-drop editor.</p>
          <%= form.text_area :workflow_data, value: (@template.workflow_data.to_json if @template.workflow_data.present?), rows: 10, class: "form-textarea font-mono text-sm" %>
        </div>
      </div>

      <%# Visual Editor (graph mode templates with existing data) %>
      <% if @template.graph_mode? && @template.workflow_data.present? %>
        <%
          # Create a workflow-like object for the visual editor partial
          start_uuid = @template.start_node_uuid || @template.workflow_data&.first&.dig("id")
          template_workflow_struct = Struct.new(:id, :steps, :start_step, keyword_init: true) do
            def graph_mode? = true
          end
          fake_start = start_uuid ? Struct.new(:uuid).new(start_uuid) : nil
          template_as_workflow = template_workflow_struct.new(
            id: @template.id,
            steps: [],
            start_step: fake_start
          )
        %>
        <%= render partial: "workflows/visual_editor", locals: { workflow: template_as_workflow } %>
      <% end %>
    </div>

    <div class="card__footer flex justify-end gap-3">
      <%= link_to admin_templates_path, class: "btn btn--plain" do %>
        Cancel
      <% end %>
      <%= form.submit "Update Template", class: "btn btn--primary" %>
    </div>
  <% end %>
</div>
