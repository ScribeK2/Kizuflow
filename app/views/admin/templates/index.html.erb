<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4 flex items-center justify-between">
    <div>
      <h1>Template Management</h1>
      <p class="text-sm mt-1">Create, edit, and manage workflow templates.</p>
    </div>
    <div class="flex gap-2">
      <%= link_to admin_root_path, class: "btn btn--secondary flex items-center gap-2" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
        </svg>
        Back to Dashboard
      <% end %>
      <%= link_to new_admin_template_path, class: "btn btn--primary flex items-center gap-2" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
        New Template
      <% end %>
    </div>
  </div>

  <!-- Templates List -->
  <% if @templates.any? %>
    <div class="card">
      <% @templates.each do |template| %>
        <div class="wf-list-item">
          <div class="wf-list-item__info flex-1 min-w-0">
            <div class="flex items-center gap-3 mb-2">
              <h3 class="wf-list-item__title"><%= template.name %></h3>
              <% if template.is_public? %>
                <span class="badge badge--published">Public</span>
              <% else %>
                <span class="badge">Private</span>
              <% end %>
              <% if template.category.present? %>
                <span class="badge"><%= template.category %></span>
              <% end %>
            </div>
            <% if template.description.present? %>
              <p class="text-sm mb-2"><%= truncate(template.description, length: 150) %></p>
            <% end %>
            <p class="wf-list-item__meta">
              <%= pluralize(template.workflow_data&.length || 0, "step") %> &bull; Created <%= time_ago_in_words(template.created_at) %> ago
            </p>
          </div>
          <div class="flex items-center gap-2 ml-4">
            <%= link_to edit_admin_template_path(template), class: "btn btn--secondary btn--sm" do %>
              Edit
            <% end %>
            <%= link_to admin_template_path(template), data: { turbo_method: :delete, turbo_confirm: "Are you sure you want to delete this template?" }, class: "btn btn--negative btn--sm" do %>
              Delete
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <h3 class="empty-state__title">No templates</h3>
      <p class="empty-state__text">Get started by creating a new template.</p>
      <div class="mt-4">
        <%= link_to new_admin_template_path, class: "btn btn--primary flex items-center gap-2" do %>
          <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          New Template
        <% end %>
      </div>
    </div>
  <% end %>
</div>
