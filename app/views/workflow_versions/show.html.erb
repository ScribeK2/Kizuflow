<div class="max-w-4xl mx-auto px-4 py-8">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900 dark:text-white">
        <%= @version.metadata_snapshot["title"] %> — v<%= @version.version_number %>
      </h1>
      <p class="text-sm text-gray-500 dark:text-gray-400 mt-1">
        Published by <%= @version.published_by.email %> on <%= @version.published_at.strftime("%b %d, %Y %H:%M") %>
      </p>
      <% if @version.changelog.present? %>
        <p class="text-sm text-gray-600 dark:text-gray-300 mt-2 italic"><%= @version.changelog %></p>
      <% end %>
    </div>
    <div class="flex space-x-3">
      <% if @workflow.can_be_edited_by?(current_user) && @version != @workflow.published_version %>
        <%= button_to "Restore This Version", restore_workflow_version_path(@workflow, @version),
            method: :post,
            class: "inline-flex items-center px-4 py-2 border border-amber-300 dark:border-amber-600 text-sm font-medium rounded-md text-amber-700 dark:text-amber-400 bg-amber-50 dark:bg-amber-900/20 hover:bg-amber-100 dark:hover:bg-amber-900/40",
            data: { turbo_confirm: "Restore this version? This will overwrite the current draft steps." } %>
      <% end %>
      <%= link_to "All Versions", versions_workflow_path(@workflow),
          class: "inline-flex items-center px-4 py-2 border border-gray-300 dark:border-gray-600 text-sm font-medium rounded-md text-gray-700 dark:text-gray-300 bg-white dark:bg-gray-800 hover:bg-gray-50 dark:hover:bg-gray-700" %>
    </div>
  </div>

  <div class="bg-white dark:bg-gray-800 shadow rounded-lg p-6">
    <h2 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">
      Steps (<%= @version.steps_snapshot.length %>)
    </h2>
    <div class="space-y-3">
      <% @version.steps_snapshot.each_with_index do |step, index| %>
        <div class="border border-gray-200 dark:border-gray-700 rounded-lg p-4">
          <div class="flex items-center space-x-3">
            <span class="inline-flex items-center justify-center w-6 h-6 rounded-full bg-gray-100 dark:bg-gray-700 text-xs font-medium text-gray-600 dark:text-gray-400">
              <%= index + 1 %>
            </span>
            <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium
              <%= case step['type']
                  when 'question' then 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-400'
                  when 'action' then 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-400'
                  when 'message' then 'bg-gray-100 text-gray-700 dark:bg-gray-900/30 dark:text-gray-400'
                  when 'escalate' then 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-400'
                  when 'resolve' then 'bg-emerald-100 text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-400'
                  when 'sub_flow' then 'bg-amber-100 text-amber-700 dark:bg-amber-900/30 dark:text-amber-400'
                  else 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300'
                  end %>">
              <%= step['type']&.humanize %>
            </span>
            <span class="text-sm font-medium text-gray-900 dark:text-white"><%= step['title'] %></span>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</div>
