<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4">
    <h1>Templates</h1>
    <p class="text-sm mt-1">Browse and use pre-built workflow templates.</p>
  </div>

  <!-- Search Section -->
  <div class="card card__body mb-4">
    <%= form_with url: templates_path, method: :get, local: true, class: "flex gap-2" do |form| %>
      <%= hidden_field_tag :category, params[:category] if params[:category].present? %>
      <%= form.text_field :search, value: params[:search], placeholder: "Search templates...", class: "form-input flex-1" %>
      <%= form.submit "Search", class: "btn btn--secondary" %>
      <% if params[:search].present? || params[:category].present? %>
        <%= link_to "Clear", templates_path, class: "btn btn--plain" %>
      <% end %>
    <% end %>
  </div>

  <!-- Category Filter Chips -->
  <% categories = @categories %>
  <% if categories.any? %>
    <div class="flex flex-wrap gap-2 mb-4">
      <%= link_to "All", templates_path(search: params[:search]),
          class: "badge #{params[:category].blank? ? 'badge--active' : ''}",
          data: { turbo_action: "replace" } %>
      <% categories.each do |cat| %>
        <%= link_to cat.titleize, templates_path(category: cat, search: params[:search]),
            class: "badge #{params[:category] == cat ? 'badge--active' : ''}",
            data: { turbo_action: "replace" } %>
      <% end %>
    </div>
  <% end %>

  <% if @templates.any? %>
    <div class="template-grid">
      <% @templates.each do |template| %>
        <%
          steps_count = template.workflow_data&.length || 0
        %>
        <div class="card template-card <%= steps_count == 0 ? 'is-disabled' : '' %>">
          <div class="card__body flex flex-col h-full">
            <div class="flex items-start justify-between mb-2 gap-2">
              <h3 class="font-semibold flex-1 min-w-0">
                <%= link_to template.name, template_path(template) %>
              </h3>
              <span class="badge flex-shrink-0"><%= template.category&.titleize %></span>
            </div>
            <p class="text-sm mb-4 flex-1"><%= truncate(template.description || "", length: 100) %></p>

            <p class="text-xs mb-4"><%= pluralize(steps_count, "step") %></p>

            <% if steps_count == 0 %>
              <p class="text-xs italic text-center mb-4">No steps yet</p>
            <% end %>

            <div class="card__footer mt-auto pt-3 grid grid-cols-2 gap-2">
              <button type="button"
                      data-controller="template-preview"
                      data-template-preview-template-id-value="<%= template.id %>"
                      data-action="click->template-preview#open"
                      class="btn btn--secondary btn--sm">
                Preview
              </button>
              <%= button_to "Use Template", use_template_path(template), method: :post, class: "btn btn--primary btn--sm" %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">
      <svg class="empty-state__icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
      </svg>
      <p class="empty-state__text">No templates found.</p>
    </div>
  <% end %>
</div>

<%# Include preview modals %>
<% if @templates.any? %>
  <%= render partial: "preview_modal", locals: { templates: @templates } %>
<% end %>
