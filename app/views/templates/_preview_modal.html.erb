<%# Template Preview Modal %>
<% templates.each do |template| %>
  <div id="template-preview-modal-<%= template.id %>"
       class="dialog-overlay is-hidden"
       data-controller="modal"
       data-modal-target="backdrop"
       data-action="click->modal#backdropClick">
    <div class="dialog dialog--wide"
         data-modal-target="content">

      <%# Header %>
      <div class="dialog__header">
        <div class="template-preview__header-row">
          <h2 class="dialog__title truncate"><%= template.name %></h2>
          <span class="badge flex-shrink-0"><%= template.category&.titleize %></span>
          <span class="text-sm flex-shrink-0"><%= pluralize(template.workflow_data&.length || 0, "step") %></span>
        </div>
        <button type="button"
                data-action="click->modal#close"
                class="dialog__close">
          <span class="sr-only">Close</span>
          <svg class="icon" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
      </div>

      <% if template.description.present? %>
        <div class="px-6 pt-4">
          <p class="text-sm"><%= template.description %></p>
        </div>
      <% end %>

      <% if template.workflow_data.present? && template.workflow_data.any? %>
        <%# Flow Preview %>
        <div data-controller="template-flow-preview"
             data-template-flow-preview-compact-value="false"
             id="modal-preview-<%= template.id %>">
          <script type="application/json" data-template-flow-preview-steps-data="<%= template.id %>">
            <%= raw json_escape(template.workflow_data.to_json) %>
          </script>

          <%# Zoom toolbar %>
          <div class="template-preview__toolbar">
            <div class="template-preview__zoom-controls">
              <button type="button" data-action="click->template-flow-preview#zoomOut" class="btn btn--plain btn--sm" title="Zoom out">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM13 10H7"/></svg>
              </button>
              <span data-template-flow-preview-target="zoomLevel" class="text-xs font-medium min-w-12 text-center">100%</span>
              <button type="button" data-action="click->template-flow-preview#zoomIn" class="btn btn--plain btn--sm" title="Zoom in">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0zM10 7v6m3-3H7"/></svg>
              </button>
              <button type="button" data-action="click->template-flow-preview#fitToScreen" class="btn btn--plain btn--sm" title="Fit to screen">
                <svg class="icon icon--sm" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4"/></svg>
              </button>
            </div>
            <span class="text-xs">Ctrl+scroll to zoom, Alt+drag to pan</span>
          </div>

          <%# Canvas %>
          <div data-template-flow-preview-target="canvas"
               class="template-flow-container relative overflow-auto mx-6 mt-3 mb-4"
               style="min-height: 350px; max-height: 500px;">
            <p class="text-center py-8">Loading preview...</p>
          </div>
        </div>
      <% else %>
        <div class="empty-state mx-6 my-4" style="min-height: 200px;">
          <p class="empty-state__text">No steps defined in this template.</p>
        </div>
      <% end %>

      <%# Footer actions %>
      <div class="dialog__footer">
        <button type="button"
                data-action="click->modal#close"
                class="btn btn--plain">
          Close
        </button>
        <%= button_to "Use This Template", use_template_path(template), method: :post, class: "btn btn--primary" %>
      </div>
    </div>
  </div>
<% end %>
