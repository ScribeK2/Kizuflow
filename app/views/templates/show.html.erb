<div class="page-content">
  <!-- Header Section -->
  <div class="mb-4">
    <h1 class="mb-2"><%= @template.name %></h1>
    <p class="text-sm"><%= @template.description %></p>
    <span class="badge mt-2"><%= @template.category %></span>
  </div>

  <%# Flow Preview %>
  <% if @template.workflow_data.present? && @template.workflow_data.any? %>
    <div class="card mb-4">
      <div class="card__header">
        <h2>Flow Diagram</h2>
      </div>
      <div class="card__body">
        <div class="template-flow-container"
             data-controller="template-flow-preview"
             data-template-flow-preview-compact-value="false"
             id="template-preview-<%= @template.id %>">
          <script type="application/json" data-template-flow-preview-steps-data="<%= @template.id %>">
            <%= raw json_escape(@template.workflow_data.to_json) %>
          </script>
          <div data-template-flow-preview-target="canvas"
               class="relative overflow-auto"
               style="min-height: 300px; max-height: 600px;">
            <p class="text-center py-8">Loading preview...</p>
          </div>
        </div>
      </div>
    </div>
  <% end %>

  <div class="card mb-4">
    <div class="card__header">
      <h2>Template Steps</h2>
    </div>
    <% if @template.workflow_data.present? && @template.workflow_data.any? %>
      <div class="card__body">
        <% @template.workflow_data.each_with_index do |step, index| %>
          <div class="card mb-3">
            <div class="card__body flex items-start gap-3">
              <span class="admin-step-number flex-shrink-0">
                <%= index + 1 %>
              </span>
              <div class="flex-1">
                <div class="flex items-center mb-2">
                  <h3 class="font-semibold"><%= step['title'] %></h3>
                  <span class="badge ml-3"><%= step['type'] %></span>
                </div>
                <% if step['description'].present? %>
                  <p class="text-sm"><%= step['description'] %></p>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="empty-state p-4">
        <p class="empty-state__text">No steps defined in this template.</p>
      </div>
    <% end %>
  </div>

  <div class="flex justify-end">
    <%= button_to "Use This Template", use_template_path(@template), method: :post, class: "btn btn--primary" %>
  </div>
</div>
