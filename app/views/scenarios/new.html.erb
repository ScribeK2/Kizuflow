<div class="page-content">
  <div class="mb-4">
    <h1>Start Scenario</h1>
    <p class="text-sm mt-1">Run the workflow step-by-step to test its logic and flow.</p>
  </div>

  <%= form_with model: Scenario.new, url: workflow_scenarios_path(@workflow), local: true, class: "card" do |form| %>
    <%= form.hidden_field :workflow_id, value: @workflow.id %>

    <% if @scenario && @scenario.errors.any? %>
      <div class="card__body">
        <div class="flash flash--alert">
          <div class="flash__body">
            <p class="font-medium"><%= pluralize(@scenario.errors.count, "error") %> prohibited this scenario from starting:</p>
            <ul class="list-disc pl-5 mt-2 text-sm">
              <% @scenario.errors.full_messages.each do |message| %>
                <li><%= message %></li>
              <% end %>
            </ul>
          </div>
        </div>
      </div>
    <% end %>

    <div class="card__body">
      <h2 class="font-bold mb-2"><%= @workflow.title %></h2>
      <% if @workflow.description.present? %>
        <p class="text-sm mb-4"><%= @workflow.description_text %></p>
      <% end %>
      <p class="text-sm">
        You'll progress through each step one at a time, providing answers as you go.
        The workflow will automatically route based on your responses and transition conditions.
      </p>

      <div class="admin-info-box admin-info-box--info mt-4">
        <h3 class="text-sm font-semibold mb-2">How it works:</h3>
        <ul class="text-sm list-disc list-inside">
          <li>Start with the first step</li>
          <li>Answer questions or review action instructions</li>
          <li>Progress through branches based on your answers</li>
          <li>Complete the workflow to see the full execution path</li>
        </ul>
      </div>
    </div>

    <div class="card__footer flex justify-end gap-3">
      <%= link_to "Back", workflow_path(@workflow), class: "btn btn--plain" %>
      <%= form.submit "Start Scenario", class: "btn btn--primary" %>
    </div>
  <% end %>
</div>
