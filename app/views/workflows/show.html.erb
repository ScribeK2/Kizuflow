<div class="page-content">
  <!-- Header Section -->
  <div class="wf-page-header mb-6">
    <div class="wf-show-step__body">
      <h1 class="wf-page-header__title"><%= @workflow.title %></h1>
      <% if @workflow.has_description? %>
        <div class="mt-2">
          <%= @workflow.description %>
        </div>
      <% end %>
    </div>
    <div class="wf-page-header__actions--col">
      <% if @workflow.can_be_viewed_by?(current_user) %>
        <% if @workflow.is_public? %>
          <span class="badge badge--published">Public Workflow</span>
        <% end %>
        <% if @workflow.published_version.present? %>
          <%= link_to "v#{@workflow.published_version.version_number} — #{@workflow.published_version.published_at.strftime('%b %d, %Y')}",
              versions_workflow_path(@workflow),
              class: "badge" %>
        <% end %>
      <% end %>
      <div class="wf-btn-group">
        <% if @workflow.can_be_edited_by?(current_user) %>
          <%= link_to edit_workflow_path(@workflow), class: "btn btn--secondary btn--sm" do %>
            <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
            </svg>
            Edit
          <% end %>
          <div data-controller="dialog" class="inline-flex">
            <button type="button" data-action="dialog#open" class="btn btn--positive btn--sm">
              Publish
            </button>
            <%= render "publish_modal", workflow: @workflow %>
          </div>
        <% end %>
        <% if @workflow.can_be_viewed_by?(current_user) %>
          <%= link_to export_workflow_path(@workflow), class: "btn btn--plain btn--sm" do %>
            <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4" />
            </svg>
            Export JSON
          <% end %>
          <%= link_to export_pdf_workflow_path(@workflow), class: "btn btn--plain btn--sm" do %>
            <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 21h10a2 2 0 002-2V9.414a1 1 0 00-.293-.707l-5.414-5.414A1 1 0 0012.586 3H7a2 2 0 00-2 2v14a2 2 0 002 2z" />
            </svg>
            Export PDF
          <% end %>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Workflow Steps Section -->
  <div class="card">
    <div class="card__header">
      <h2 class="font-bold">Workflow Steps</h2>
    </div>
    <% display_steps = workflow_display_steps(@workflow) %>
    <% if display_steps.present? && display_steps.any? %>
      <div class="card__body wf-steps-stack">
        <% display_steps.each_with_index do |step, index| %>
          <div class="card" data-controller="image-lightbox" data-step-type="<%= step_field(step, 'type') %>">
            <div class="card__body">
              <div class="wf-show-step">
                <span class="step-card__number">
                  <%= index + 1 %>
                </span>
                <div class="wf-show-step__body">
                  <div class="wf-show-step__title-row">
                    <h3 class="font-semibold"><%= step_field(step, 'title') %></h3>
                    <span class="badge"><%= step_field(step, 'type') %></span>
                  </div>
                  <% if step_field(step, 'description').present? %>
                    <div class="text-sm"><%= render_step_content(step, 'description') %></div>
                  <% end %>
                  <% if step_field(step, 'type') == 'question' && step_field(step, 'question').present? %>
                    <p class="text-sm mt-1">Q: <%= step_field(step, 'question') %></p>
                  <% end %>
                  <% if step_field(step, 'type') == 'action' && step_field(step, 'instructions').present? %>
                    <div class="text-sm mt-2">
                      <strong>Instructions:</strong>
                      <%= render_step_content(step, 'instructions') %>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <div class="card__body text-center py-8">
        <svg class="icon icon--xl mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
        </svg>
        <p>
          No steps defined yet. <%= link_to "Edit workflow", edit_workflow_path(@workflow), class: "font-medium" %> to add steps.
        </p>
      </div>
    <% end %>
  </div>

  <!-- Action Button -->
  <div class="wf-action-footer">
    <% if current_user&.can_edit_workflows? %>
      <%= link_to new_workflow_scenario_path(@workflow), class: "btn btn--positive" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Run Scenario
      <% end %>
    <% else %>
      <%= link_to start_workflow_path(@workflow), class: "btn btn--positive" do %>
        <svg class="icon icon--sm" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14.752 11.168l-3.197-2.132A1 1 0 0010 9.87v4.263a1 1 0 001.555.832l3.197-2.132a1 1 0 000-1.664z" />
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
        </svg>
        Start Workflow
      <% end %>
    <% end %>
  </div>
</div>
